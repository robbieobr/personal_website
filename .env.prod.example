# === REQUIRED: Change all values before deploying ===

# MySQL root (used only during DB initialization)
MYSQL_ROOT_PASSWORD=change_me_strong_root_password

# Read-only app user (backend connects with these credentials)
DB_READONLY_USER=webapp
DB_READONLY_PASSWORD=change_me_strong_webapp_password

# Backend
DB_HOST=mysql
DB_PORT=3306
DB_NAME=personal_website
PORT=5000
NODE_ENV=production

# CORS — set to your actual domain (with https://)
ALLOWED_ORIGINS=https://yourdomain.com
