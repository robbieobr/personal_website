{
  "name": "personal-website-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "axios": "^1.4.0",
    "i18next": "^23.7.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.1",
    "react-loading-skeleton": "^3.3.1"
  },
  "scripts": {
    "dev": "vite",
    "dev:mock": "cross-env VITE_API_BACKEND=http://localhost:5001 vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "start": "npm run preview",
    "type-check": "tsc --noEmit",
    "mock": "node ./mock/mockServer.js",
    "mock:install": "cd mock && npm install || true",
    "postinstall": "npm run mock:install",
    "test": "npm run test:unit && npm run test:ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^7.0.3",
    "jsdom": "^28.1.0",
    "typescript": "^4.9.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
