# Frontend Environment Variables

# API Configuration - Used by vite.config.ts proxy
# Default: http://localhost:5000 (local backend)
# For mock server: http://localhost:5001
# For Docker: http://backend:5000
VITE_API_BACKEND=http://localhost:5000

# API URL - Used for direct API calls (if needed)
VITE_API_URL=http://localhost:5000/api
