# Production Frontend Environment Variables
# Copy to frontend/.env.production and fill in real values before running a production build.
# This file is safe to commit — it contains no real credentials.

# API Configuration
VITE_API_BACKEND=http://backend:5000
VITE_API_URL=http://localhost:5000/api

# App URL — displayed as the header link text in production builds.
# Set this to your site's public URL (with https://).
VITE_APP_URL=https://yourdomain.com
