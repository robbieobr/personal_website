-- Job history — userId references the id assigned above (usually 1 for the first insert)
-- endDate is NULL for a current role
INSERT INTO job_history (userId, company, position, startDate, endDate, description) VALUES
(1, 'Current Company', 'Current Role', '2022-01-01', NULL,       'What you do there.'),
(1, 'Previous Company', 'Previous Role', '2019-06-01', '2021-12-31', 'What you did there.');

-- Education — same userId convention
